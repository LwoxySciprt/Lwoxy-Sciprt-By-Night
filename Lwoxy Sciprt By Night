local function _re()
    for _, o in pairs(_eo) do
        pcall(function() if o and o.Parent then o:Destroy() end end)
    end
    _eo = {}
    _edl = {}
end

local function _ce(model, color, label)
    if not model or not model:IsA("Model") then return end
    local rp = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Head") or model:FindFirstChild("Torso") or model:FindFirstChild("UpperTorso") or model:FindFirstChildWhichIsA("BasePart")
    if not rp then return end

    local bb = Instance.new("BillboardGui")
    bb.Name = "LE"
    bb.Parent = rp
    bb.Size = UDim2.new(0, 180, 0, 48)
    bb.StudsOffset = Vector3.new(0, 3.5, 0)
    bb.AlwaysOnTop = true
    bb.MaxDistance = 4000
    bb.LightInfluence = 0
    table.insert(_eo, bb)

    local bg = Instance.new("Frame")
    bg.Parent = bb
    bg.BackgroundColor3 = Color3.fromRGB(8, 6, 16)
    bg.BackgroundTransparency = 0.25
    bg.Size = UDim2.new(1, 0, 0, 28)
    bg.BorderSizePixel = 0
    _cr(bg, 6)
    _st(bg, color, 1, 0.4)

    local nl = Instance.new("TextLabel")
    nl.Parent = bg
    nl.BackgroundTransparency = 1
    nl.Size = UDim2.new(1, 0, 1, 0)
