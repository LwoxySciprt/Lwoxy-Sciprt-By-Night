    nl.TextSize = 12
    nl.TextXAlignment = Enum.TextXAlignment.Left
    nl.TextColor3 = idx == 1 and Color3.fromRGB(200, 180, 255) or Color3.fromRGB(120, 110, 150)

    b.MouseEnter:Connect(function()
        if _cur ~= name then
            _tw(b, _ti(0.15), {BackgroundTransparency = 0.4}):Play()
            _tw(nl, _ti(0.15), {TextColor3 = Color3.fromRGB(180, 160, 240)}):Play()
            _tw(il, _ti(0.15), {TextColor3 = Color3.fromRGB(160, 120, 240)}):Play()
        end
    end)
    b.MouseLeave:Connect(function()
        if _cur ~= name then
            _tw(b, _ti(0.15), {BackgroundTransparency = 0.85}):Play()
            _tw(nl, _ti(0.15), {TextColor3 = Color3.fromRGB(120, 110, 150)}):Play()
            _tw(il, _ti(0.15), {TextColor3 = Color3.fromRGB(100, 90, 140)}):Play()
        end
    end)

    b.MouseButton1Click:Connect(function()
        _cur = name
        MP.Visible = false; DP.Visible = false
        panel.Visible = true

        for _, ch in ipairs(SP:GetChildren()) do
            if ch:IsA("TextButton") then
                _tw(ch, _ti(0.2), {BackgroundTransparency = 0.85}):Play()
                for _, lb in ipairs(ch:GetChildren()) do
                    if lb:IsA("TextLabel") then
                        _tw(lb, _ti(0.2), {TextColor3 = lb.Name == "Icon" and Color3.fromRGB(100, 90, 140) or Color3.fromRGB(120, 110, 150)}):Play()
                    end
                end
            end
        end
        _tw(b, _ti(0.2), {BackgroundTransparency = 0}):Play()
        _tw(nl, _ti(0.2), {TextColor3 = Color3.fromRGB(200, 180, 255)}):Play()
        _tw(il, _ti(0.2), {TextColor3 = Color3.fromRGB(180, 130, 255)}):Play()
        _tw(AI, _ti(0.3, Enum.EasingStyle.Quart), {Position = UDim2.new(0, 0, 0, 34 + (idx - 1) * 48 + 5)}):Play()

        -- Panel fade
