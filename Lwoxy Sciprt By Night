    nl.TextColor3 = color
    nl.TextSize = 12
    nl.TextStrokeTransparency = 0.6
    nl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)

    local dl = Instance.new("TextLabel")
    dl.Parent = bb
    dl.BackgroundTransparency = 1
    dl.Position = UDim2.new(0, 0, 0, 30)
