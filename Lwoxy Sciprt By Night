    dl.Text = "0m"
    dl.TextColor3 = Color3.fromRGB(180, 170, 210)
    dl.TextSize = 10
    dl.TextStrokeTransparency = 0.7

    local hl = Instance.new("Highlight")
    hl.Name = "LH"
    hl.Parent = model
    hl.FillColor = color
    hl.FillTransparency = 0.75
    hl.OutlineColor = color
    hl.OutlineTransparency = 0.2
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    table.insert(_eo, hl)

    table.insert(_edl, {label = dl, model = model})
end

local function _rf()
    _re()
    if not _esp then return end

    -- All players
    for _, pl in ipairs(P:GetPlayers()) do
        if pl ~= LP and pl.Character then
            local hum = pl.Character:FindFirstChildWhichIsA("Humanoid")
            local hp = hum and math.floor(hum.Health) or "?"
            local mhp = hum and math.floor(hum.MaxHealth) or "?"
            _ce(pl.Character, Color3.fromRGB(255, 60, 80), pl.DisplayName .. " [" .. hp .. "/" .. mhp .. "]")
        end
    end

    -- Scan everything
    local function _scan(parent, depth)
        if depth > 4 then return end
        for _, obj in ipairs(parent:GetChildren()) do
            if obj:IsA("Model") then
                local isPlayer = false
                for _, pl in ipairs(P:GetPlayers()) do
                    if pl.Character == obj then isPlayer = true break end
                end

                if not isPlayer and obj ~= LP.Character then
                    local hum = obj:FindFirstChildWhichIsA("Humanoid")
                    if hum then
                        local hp = math.floor(hum.Health)
                        local mhp = math.floor(hum.MaxHealth)
                        local col, pfx

                        if hp <= 0 then
                            col = Color3.fromRGB(80, 80, 100)
                            pfx = "Dead: "
                        elseif mhp > 500 then
                            col = Color3.fromRGB(255, 40, 40)
                            pfx = "Boss: "
                        elseif mhp > 150 then
                            col = Color3.fromRGB(255, 120, 30)
                            pfx = "Monster: "
                        else
                            col = Color3.fromRGB(50, 200, 255)
                            pfx = "NPC: "
                        end

                        _ce(obj, col, pfx .. obj.Name .. " [" .. hp .. "/" .. mhp .. "]")
                    else
                        -- Non-humanoid models with parts
                        local pc = 0
                        for _, p in ipairs(obj:GetDescendants()) do
                            if p:IsA("BasePart") then pc = pc + 1 end
                        end
                        if pc >= 3 then
                            _ce(obj, Color3.fromRGB(200, 180, 50), obj.Name)
                        end
                    end
                end
            end

            if obj:IsA("Folder") or obj:IsA("Model") then
                pcall(function() _scan(obj, depth + 1) end)
            end
        end
    end

    _scan(WS, 0)
end

