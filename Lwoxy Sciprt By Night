        for _, ch in ipairs(panel:GetChildren()) do
            if ch:IsA("GuiObject") then ch.BackgroundTransparency = 1 end
        end
        _tw(panel, _ti(0.25), {BackgroundTransparency = 0}):Play()
        task.wait(0.05)
        for _, ch in ipairs(panel:GetChildren()) do
            if ch:IsA("Frame") then _tw(ch, _ti(0.3), {BackgroundTransparency = 0}):Play() end
        end
    end)

    return b
end

